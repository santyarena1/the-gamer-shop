generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(EMPLOYEE)
  avatar      String?
  phone       String?
  position    String?
  baseSalary  Decimal? @db.Decimal(12, 2)
  ipcAdjusted Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks        Task[]      @relation("AssignedTo")
  createdTasks Task[]      @relation("CreatedBy")
  salaries      Salary[]
  debts         Debt[]
  purchases     Purchase[]
  investments   Investment[]
  corporateCard CorporateCard?
  quoteThreads       QuoteThread[]       @relation("QuoteThreadAuthor")
  quoteMessages      QuoteMessage[]      @relation("QuoteMessageAuthor")
  quoteCatalogItems  QuoteCatalogItem[]
  quoteDocuments     QuoteDocument[]
  pcBuildTemplates   PcBuildTemplate[]
  flyerGenerations   FlyerGeneration[]

  @@map("users")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedTo   User   @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String
  createdBy    User   @relation("CreatedBy", fields: [createdById], references: [id])
  createdById  String

  @@map("tasks")
}

model MonthlyIpc {
  id         String   @id @default(cuid())
  month      Int
  year       Int
  percentage Decimal  @db.Decimal(6, 3)
  createdAt  DateTime @default(now())

  @@unique([month, year])
  @@map("monthly_ipc")
}

model Salary {
  id             String       @id @default(cuid())
  month          Int
  year           Int
  previousBase   Decimal      @db.Decimal(12, 2)
  ipcPercentage  Decimal?     @db.Decimal(6, 3)
  ipcIncrease    Decimal      @default(0) @db.Decimal(12, 2)
  grossAmount    Decimal      @db.Decimal(12, 2)
  debtDeduction  Decimal      @default(0) @db.Decimal(12, 2)
  amount         Decimal      @db.Decimal(12, 2)
  paid           Boolean      @default(false)
  paidAt         DateTime?
  status         SalaryStatus @default(PENDING)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  userId   String
  payments SalaryPayment[]
  debts    SalaryDebt[]

  @@unique([userId, month, year])
  @@map("salaries")
}

model SalaryPayment {
  id           String      @id @default(cuid())
  amount       Decimal     @db.Decimal(12, 2)
  currency     Currency    @default(ARS)
  exchangeRate Decimal     @default(1) @db.Decimal(12, 4)
  amountArs    Decimal     @db.Decimal(12, 2)
  type         PaymentType @default(PARTIAL)
  paidAt       DateTime    @default(now())
  notes        String?
  createdAt    DateTime    @default(now())

  salary   Salary @relation(fields: [salaryId], references: [id], onDelete: Cascade)
  salaryId String

  @@map("salary_payments")
}

model SalaryDebt {
  salary   Salary @relation(fields: [salaryId], references: [id], onDelete: Cascade)
  salaryId String
  debt     Debt   @relation(fields: [debtId], references: [id])
  debtId   String
  amount   Decimal @db.Decimal(12, 2)

  @@id([salaryId, debtId])
  @@map("salary_debts")
}

model Debt {
  id          String    @id @default(cuid())
  description String
  amount      Decimal   @db.Decimal(10, 2)
  paid        Boolean   @default(false)
  paidAt      DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  user        User                    @relation(fields: [userId], references: [id])
  userId      String
  salaryDebts SalaryDebt[]
  statement   CorporateCardStatement?

  @@map("debts")
}

model CorporateCard {
  id        String   @id @default(cuid())
  label     String   @default("Tarjeta empresarial")
  lastFour  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String                   @unique
  statements CorporateCardStatement[]

  @@map("corporate_cards")
}

model CorporateCardStatement {
  id          String    @id @default(cuid())
  month       Int
  year        Int
  totalAmount Decimal   @db.Decimal(12, 2)
  closingDate DateTime?
  dueDate     DateTime?
  paid        Boolean   @default(false)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())

  card   CorporateCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId String
  debt   Debt?         @relation(fields: [debtId], references: [id], onDelete: SetNull)
  debtId String?        @unique

  @@unique([cardId, month, year])
  @@map("corporate_card_statements")
}

model Purchase {
  id          String   @id @default(cuid())
  item        String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  category    String   @default("Componente")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@map("purchases")
}

model Investment {
  id          String           @id @default(cuid())
  amount      Decimal          @db.Decimal(10, 2)
  description String
  status      InvestmentStatus @default(ACTIVE)
  returnRate  Decimal?         @db.Decimal(5, 2)
  startDate   DateTime         @default(now())
  endDate     DateTime?
  createdAt   DateTime         @default(now())

  investor   User   @relation(fields: [investorId], references: [id])
  investorId String

  @@map("investments")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SalaryStatus {
  PENDING
  CONFIRMED
  PARTIAL
  PAID
}

enum PaymentType {
  PARTIAL
  ADVANCE
  FINAL
}

enum Currency {
  ARS
  USD
  USDT
  OTHER
}

enum ExpenseCategory {
  UTILITIES
  INTERNET
  PROFESSIONAL
  PAYROLL_TAXES
  CHECKS
  RENT
  INSURANCE
  OTHER
}

model RecurringVendor {
  id          String          @id @default(cuid())
  name        String
  category    ExpenseCategory @default(OTHER)
  description String?
  payUntilDay Int? @map("typicalDay") // Plazo habitual: del día 1 al X de cada mes
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  payments RecurringPayment[]

  @@map("recurring_vendors")
}

model RecurringPayment {
  id        String    @id @default(cuid())
  month     Int
  year      Int
  amount    Decimal   @default(0) @db.Decimal(12, 2)
  paid      Boolean   @default(false)
  paidAt    DateTime?
  dueDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vendor   RecurringVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorId String

  @@unique([vendorId, month, year])
  @@map("recurring_payments")
}

model QuoteThread {
  id          String   @id @default(cuid())
  clientName  String?
  clientPhone String?
  subject     String?
  statusLabel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User            @relation("QuoteThreadAuthor", fields: [authorId], references: [id])
  authorId  String
  messages  QuoteMessage[]
  documents QuoteDocument[]

  @@map("quote_threads")
}

model QuoteMessage {
  id          String   @id @default(cuid())
  body        String?
  fileName    String?
  filePath    String?
  mimeType    String?
  isAction    Boolean  @default(false)
  actionLabel String?
  createdAt   DateTime @default(now())

  thread   QuoteThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String
  author   User        @relation("QuoteMessageAuthor", fields: [authorId], references: [id])
  authorId String

  @@map("quote_messages")
}

model QuoteQuickButton {
  id        String  @id @default(cuid())
  label     String
  variant   String  @default("default")
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  @@map("quote_quick_buttons")
}

enum PcComponentSlot {
  CPU
  MOTHER
  RAM
  GPU
  STORAGE
  PSU
  CASE
  COOLER
  MONITOR
  OTHER
}

enum QuoteLineSourceType {
  ACUSTOCK
  CUSTOM
}

enum QuoteDocumentStatus {
  DRAFT
  CONFIRMED
  SENT
  ARCHIVED
}

model QuoteCatalogItem {
  id          String   @id @default(cuid())
  name        String
  sku         String?
  category    String   @default("Otro")
  unitPrice   Decimal  @db.Decimal(12, 2)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  @@map("quote_catalog_items")
}

model PcBuildTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  /// JSON: array of { slot, sourceType, sourceRef, name, unitPrice, qty }
  slotsJson   String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  @@map("pc_build_templates")
}

model QuoteDocument {
  id          String              @id @default(cuid())
  title       String
  clientName  String?
  clientPhone String?
  notes       String?
  status      QuoteDocumentStatus @default(DRAFT)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String
  thread   QuoteThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  threadId String?
  builds   QuoteBuild[]
  flyers   FlyerGeneration[]

  @@map("quote_documents")
}

model QuoteBuild {
  id         String   @id @default(cuid())
  label      String   @default("Configuración")
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document   QuoteDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String
  lineItems  QuoteLineItem[]

  @@map("quote_builds")
}

model QuoteLineItem {
  id         String              @id @default(cuid())
  slot       PcComponentSlot
  sourceType QuoteLineSourceType
  sourceRef  String
  name       String
  unitPrice  Decimal             @db.Decimal(12, 2)
  qty        Int                 @default(1)
  sortOrder  Int                 @default(0)

  build   QuoteBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  buildId String

  @@map("quote_line_items")
}

model AppSettings {
  id          String   @id @default("default")
  shopName    String   @default("The Gamer Shop")
  tagline     String   @default("Panel de Gestión")
  accentColor String   @default("#22c55e")
  logoUrl     String?
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

model FlyerGeneration {
  id              String   @id @default(cuid())
  templateId      String   @default("tgs_pc_gamer_1080_v1")
  title           String
  categoryLabel   String   @default("PC GAMER")
  titleLine1      String
  titleLine2      String
  payloadJson     String   @db.Text
  outputPath      String?
  caseImagePath   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author          User          @relation(fields: [authorId], references: [id])
  authorId        String
  quoteDocument   QuoteDocument? @relation(fields: [quoteDocumentId], references: [id], onDelete: SetNull)
  quoteDocumentId String?

  @@map("flyer_generations")
}

model IntegrationSettings {
  id              String   @id
  encryptedApiKey String?  @db.Text
  defaultModel    String   @default("gpt-image-1")
  updatedAt       DateTime @updatedAt

  @@map("integration_settings")
}
