# Base de datos: copiá .env.local.example → .env.local (git lo ignora; no se pierde en pull/push)
#   copy .env.local.example .env.local

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3003"
PASSWORD_RESET_SECRET="local-dev-reset"

# Integraciones opcionales
ACUSTOCK_FEED_TOKEN=
ACUSTOCK_FEED_SOLO_WEB=0
# Sync automático del feed XML (cada 1 h en dev; en Vercel usa CRON_SECRET + vercel.json)
CRON_SECRET=
# ACUSTOCK_FEED_SYNC_ENABLED=false
# ACUSTOCK_FEED_SYNC_INTERVAL_MS=3600000

SERPER_API_KEY=
OPENAI_API_KEY=
